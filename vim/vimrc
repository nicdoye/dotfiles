" 1. Start Vim-Plug
call plug#begin('~/.vim/plugged')

" 2. Declare your plugins
Plug 'hzchirs/vim-material'

" 3. CRITICAL: Close the Vim-Plug block so Vim registers the paths
call plug#end()

" 4. True Color Configuration
if has("nvim")
    set termguicolors
    set guicursor=n-v-c:block-Cursor/lCursor-blinkon0,i-ci:ver25-Cursor/lCursor,r-cr:hor20-Cursor/lCursor
    " Neovim 0.10+ needs this to stop the default 'vim' colorscheme
    " from being applied before your plugin theme loads
    set background=dark
else
    let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
    let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"
    set termguicolors
endif

" 5. GUI Specifics ---
if has("gui")
    if has("gui_gtk2")
        set guifont=Inconsolata\ 12
    elseif has("gui_win32")
        set guicursor=Consolas:h10:cANSI
    endif
endif

" 6. Theme Activation
if has('nvim') || filereadable(expand('~/.vim/plugged/vim-material/colors/vim-material.vim'))
    set background=dark
    colorscheme vim-material

    " Drop ctermbg=NONE — let guibg do all the work under termguicolors
    highlight Normal guibg=#263238
else
    colorscheme desert
endif

" 7. General Settings ---
syntax on
set nolist
set expandtab ts=4 sw=4 ai
set number
set norelativenumber

" Fix annoying highlighting of 'tabs'
let g:indent_guides_auto_colors = 0

" Filetype Detections
au BufRead,BufNewFile *.build set filetype=xml
au BufRead,BufNewFile *.aliases set filetype=sh

" Disable netrw directory history
let g:netrw_dirhistmax = 0

" FZF Path Configuration
set rtp+=/usr/local/opt/fzf
